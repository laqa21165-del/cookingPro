.custom-tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  /* 基础高度 + 安全区（iPhone Home Indicator）；env 不支持的机型 fallback 到 0 */
  height: calc(100rpx + env(safe-area-inset-bottom));
  /* 上内距固定，下内距用安全区；安卓等无安全区设备用 fallback 20rpx 防止贴底 */
  padding: 10rpx 0 max(env(safe-area-inset-bottom), 20rpx);
  background: #FFFDFB;
  
  border-top: 2rpx solid #C9A99A;
  
  /* iOS 风格圆角底边 */
  border-radius: 24rpx 24rpx 0 0;
  
  box-sizing: border-box;
  z-index: 100;
  /* 确保圆角区域外透明，不遮挡页面内容 */
  overflow: hidden;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: transparent;
  color: #9b8073;
  font-size: 26rpx;
  line-height: 1;
}

.tab-item-active {
  color: #C2674E;
  font-weight: 700;
}

.tab-icon {
  width: 50rpx;
  height: 50rpx;
}

.tab-icon-wrap {
  position: relative;
  width: 50rpx;
  height: 50rpx;
}

.tab-badge {
  position: absolute;
  top: -10rpx;
  right: -16rpx;
  min-width: 28rpx;
  height: 28rpx;
  padding: 0 6rpx;
  box-sizing: border-box;
  border-radius: 14rpx;
  background: #E24A3B;
  color: #fff;
  font-size: 20rpx;
  line-height: 28rpx;
  text-align: center;
  font-weight: 700;
  box-shadow: 0 0 0 2rpx #FFFDFB;
}
