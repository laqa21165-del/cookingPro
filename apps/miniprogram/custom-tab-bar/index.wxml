<view class="custom-tabbar">
  <view
    wx:for="{{tabs}}"
    wx:key="key"
    class="tab-item {{selected === index ? 'tab-item-active' : ''}}"
    data-index="{{index}}"
    data-path="{{item.path}}"
    bindtap="switchTab"
  >
    <view class="tab-icon-wrap">
      <image class="tab-icon" src="{{selected === index ? item.activeIcon : item.icon}}" mode="aspectFit" />
      <view wx:if="{{item.key === 'orders' && orderBadgeCount > 0}}" class="tab-badge">{{orderBadgeCount > 99 ? '99+' : orderBadgeCount}}</view>
    </view>
    <text>{{item.text}}</text>
  </view>
</view>
