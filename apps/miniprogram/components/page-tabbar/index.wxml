<view class="page-tabbar">
  <view
    wx:for="{{tabs}}"
    wx:key="key"
    class="tab-item {{selected === item.key ? 'tab-item-active' : ''}}"
    data-path="{{item.path}}"
    bindtap="switchTab"
  >
    <image class="tab-icon" src="{{selected === item.key ? item.activeIcon : item.icon}}" mode="aspectFit" />
    <text>{{item.text}}</text>
  </view>
</view>
