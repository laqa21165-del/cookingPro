{
  "meta": {
    "name": "文字点单 · 手绘风设计系统",
    "version": "1.0.0",
    "date": "2026-07-10",
    "platform": "WeChat Mini Program (rpx, 750rpx = 屏幕宽)",
    "philosophy": "Soft Organic & Healing — 有机自然、柔和治愈的手绘线条风",
    "notes": "本文件为单一事实来源。rpx 为小程序单位(750rpx=设计宽375px)，px 等价于 rpx/2，便于跨平台复用。所有描边/圆角/色值以本文件为准，覆盖现有 app.wxss 与首页实现中的细微漂移。"
  },
  "color": {
    "cream.50": "#FFF7F2",
    "cream.100": "#FDEFE7",
    "stage": "#F9F1E8",
    "surface": "#FFFDFB",
    "surface.warm": "#FFF8F1",
    "ink": "#3B251F",
    "ink.soft": "#5E463D",
    "muted": "#8E6F67",
    "muted.soft": "#96786B",
    "primary": "#C2674E",
    "primary.600": "#A8533D",
    "primary.700": "#8A3F2C",
    "primary.100": "#F6E0D7",
    "primary.tint": "#F6E2DA",
    "line": "#C9A99A",
    "line.soft": "#E0BCAA",
    "line.dashed": "#D9AE98",
    "sage": "#5F8B5B",
    "sage.100": "#EBF4E7",
    "sage.tint": "#E4F1E4",
    "onPrimary": "#FFF9F5",
    "tabbar.bg": "rgba(252,245,238,0.96)",
    "tabbar.inactive": "#9B8073"
  },
  "colorRoles": {
    "pageBackground": "cream.50",
    "cardSurface": "surface",
    "heroSurface": "surface.warm",
    "primaryAction": "primary",
    "primaryActionPress": "primary.600",
    "textPrimary": "ink",
    "textSecondary": "ink.soft",
    "textHelper": "muted",
    "handDrawnStroke": "line",
    "success": "sage",
    "successSurface": "sage.100"
  },
  "typography": {
    "fontSans": "-apple-system, 'PingFang SC', 'Microsoft YaHei', sans-serif",
    "fontHand": "'Sarasa Gothic SC', 'PingFang SC', sans-serif",
    "scale": [
      { "token": "display", "px": 26, "rpx": 52, "weight": 700, "lineHeight": 1.18, "role": "英雄标题 hero-title", "letterSpacing": "-0.03em" },
      { "token": "title", "px": 20, "rpx": 40, "weight": 700, "lineHeight": 1.24, "role": "区块标题 section-title" },
      { "token": "subtitle", "px": 18, "rpx": 36, "weight": 700, "lineHeight": 1.3, "role": "次区块标题 recent-title" },
      { "token": "card", "px": 15, "rpx": 30, "weight": 700, "lineHeight": 1.3, "role": "卡片标题 chef-name / menu-name" },
      { "token": "body", "px": 14, "rpx": 28, "weight": 400, "lineHeight": 1.6, "role": "正文" },
      { "token": "bodyStrong", "px": 14, "rpx": 28, "weight": 600, "lineHeight": 1.5, "role": "强调正文 / 小狗台词" },
      { "token": "sm", "px": 12, "rpx": 24, "weight": 400, "lineHeight": 1.5, "role": "辅助说明 muted" },
      { "token": "eyebrow", "px": 11, "rpx": 22, "weight": 600, "lineHeight": 1.4, "role": "字标 eyebrow", "letterSpacing": "0.12em" },
      { "token": "tiny", "px": 10, "rpx": 20, "weight": 600, "lineHeight": 1, "role": "标签栏文字 tab-label" }
    ]
  },
  "spacing": {
    "xs": "8rpx",
    "sm": "12rpx",
    "md": "16rpx",
    "lg": "20rpx",
    "xl": "24rpx",
    "2xl": "28rpx",
    "3xl": "32rpx",
    "4xl": "40rpx",
    "sectionGap": "34rpx",
    "pagePadX": "24rpx",
    "pagePadTop": "28rpx",
    "pagePadBottom": "164rpx",
    "base": "8rpx"
  },
  "radius": {
    "card": "24rpx",
    "cardLg": "48rpx",
    "btn": "20rpx",
    "input": "36rpx",
    "pill": "999rpx",
    "avatar": "16rpx",
    "avatarLg": "28rpx"
  },
  "stroke": {
    "width": "4rpx",
    "widthSm": "2rpx",
    "color": "#C9A99A",
    "colorSoft": "#E0BCAA",
    "dashed": "#D9AE98"
  },
  "shadow": {
    "none": "none",
    "cta": "0 16rpx 28rpx rgba(199,111,77,0.20)"
  },
  "motion": {
    "duration": "220ms",
    "easing": "cubic-bezier(0.22, 1, 0.36, 1)",
    "props": ["transform", "opacity", "box-shadow"],
    "reducedMotion": "disable transform & scale"
  },
  "components": {
    "card": { "bg": "surface", "radius": "cardLg", "border": "4rpx solid line", "shadow": "none", "padding": "32rpx" },
    "warmCard": { "bg": "surface.warm", "radius": "34rpx", "border": "2rpx solid line.soft" },
    "dashedCard": { "bg": "surface.warm", "radius": "24rpx", "border": "2rpx dashed line.dashed" },
    "primaryBtn": { "bg": "primary", "color": "onPrimary", "border": "4rpx solid primary.600", "radius": "btn", "minHeight": "84rpx", "font": "27rpx/600" },
    "secondaryBtn": { "bg": "surface", "color": "ink", "border": "4rpx solid line", "radius": "btn", "minHeight": "84rpx", "font": "27rpx/600" },
    "chip": { "radius": "pill", "height": "76rpx", "font": "24rpx/600", "gap": "10rpx" },
    "chipInvite": { "bg": "primary.tint", "color": "primary" },
    "chipBind": { "bg": "sage.tint", "color": "sage" },
    "input": { "bg": "surface", "border": "4rpx solid line", "radius": "input", "minHeight": "84rpx", "font": "28rpx", "placeholder": "muted" },
    "textarea": { "bg": "surface", "border": "4rpx solid line", "radius": "input", "minHeight": "216rpx", "font": "28rpx" },
    "avatar": { "bg": "primary.tint", "color": "primary.600", "radius": "avatar", "font": "28rpx/700" },
    "heroArt": { "size": "188rpx", "radius": "avatarLg", "bg": "#FFEFCA" },
    "tabbar": { "height": "112rpx", "bg": "tabbar.bg", "borderTop": "2rpx solid line.soft", "activeColor": "primary", "inactiveColor": "tabbar.inactive" },
    "puppyNote": { "color": "primary", "font": "24rpx/600" }
  },
  "pages": ["home", "orders", "menu", "menu-create", "me", "order-detail", "review", "bind-confirm", "order"]
}
