page {
  background: radial-gradient(circle at top left, rgba(251, 211, 189, 0.7), transparent 32%), radial-gradient(circle at bottom right, rgba(255, 227, 210, 0.78), transparent 30%), #fff8f4;
  color: #3b251f;
  font-family: 'PingFang SC', 'Microsoft YaHei', sans-serif;
}

button {
  width: auto;
  margin: 0;
  padding: 0;
  line-height: 1.3;
  border: 0;
  background: transparent;
}

button::after {
  border: 0;
}

.container {
  min-height: 100vh;
  padding: 28rpx 24rpx 164rpx;
  box-sizing: border-box;
}

.card {
  background: rgba(255, 252, 248, 0.94);
  border-radius: 28rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.88);
  box-shadow: 0 16rpx 34rpx rgba(124, 86, 68, 0.08);
  box-sizing: border-box;
}

.section-title {
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.24;
  margin-bottom: 16rpx;
  word-break: break-word;
}

.eyebrow {
  margin-bottom: 10rpx;
  color: #8e6f67;
  font-size: 22rpx;
  letter-spacing: 0.12em;
}

.muted {
  color: #8e6f67;
  font-size: 24rpx;
  line-height: 1.6;
  word-break: break-word;
}

.primary-btn,
.secondary-btn,
.ghost-btn {
  width: auto;
  min-height: 84rpx;
  padding: 0 26rpx;
  border-radius: 20rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  font-size: 27rpx;
  font-weight: 600;
  box-sizing: border-box;
  max-width: 100%;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.primary-btn {
  background: #cb6d5a;
  color: #fff9f5;
}

.secondary-btn {
  background: rgba(255, 255, 255, 0.82);
  color: #3b251f;
  border: 1rpx solid rgba(155, 103, 84, 0.12);
}

.ghost-btn {
  background: rgba(255, 255, 255, 0.62);
  color: #8e6f67;
}

.input,
.textarea {
  width: 100%;
  border-radius: 20rpx;
  border: 1rpx solid rgba(155, 103, 84, 0.16);
  background: rgba(255, 255, 255, 0.92);
  color: #3b251f;
  display: block;
  min-height: 84rpx;
  padding: 20rpx 22rpx;
  box-sizing: border-box;
  font-size: 27rpx;
  line-height: 1.5;
}

.textarea {
  min-height: 216rpx;
}

.puppy-card {
  display: flex;
  gap: 18rpx;
  align-items: center;
  padding: 16rpx 18rpx;
  border-radius: 24rpx;
  background: rgba(255, 248, 242, 0.92);
  border: 1rpx solid rgba(255, 255, 255, 0.85);
}

.puppy-img {
  width: 112rpx;
  height: 112rpx;
  flex: none;
}

.puppy-note {
  flex: 1;
  min-width: 0;
  color: #8e6f67;
  font-size: 24rpx;
  line-height: 1.5;
  word-break: break-word;
}