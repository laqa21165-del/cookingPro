.menu-page,
.menu-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.full-btn {
  width: 100%;
}

.menu-row {
  display: flex;
  gap: 18rpx;
  align-items: flex-start;
}

.menu-image {
  width: 168rpx;
  height: 168rpx;
  border-radius: 18rpx;
  background: #f4e6db;
  flex: none;
  overflow: hidden;
  position: relative;
}

.menu-image > image {
  width: 100%;
  height: 100%;
}

.menu-content {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.menu-head,
.row-actions {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12rpx;
}

.menu-name {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.32;
  word-break: break-word;
}

.status-tag.active {
  color: #4b8b60;
}

.status-tag.inactive {
  color: #b85b46;
}

.row-actions {
  flex-wrap: wrap;
  justify-content: flex-start;
}

.tiny-btn {
  min-height: 68rpx;
  padding: 0 18rpx;
  font-size: 24rpx;
}