.menu-create-btn {
  width: 96% !important;        /* 占满父容器宽度 */
  
  display: flex;
  position: relative;
  z-index: 2;
  width: calc(100% - 24rpx);
  margin: 0 20rpx 40rpx;
  min-height: 96rpx;
  border-radius: 28rpx;
  background: var(--primary);
  color: var(--on-primary);
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 700;
}

.menu-row {
  display: flex;
  flex-direction: row;
  gap: 22rpx;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  align-items: flex-start;      /* 顶部对齐 */
}
.menu-left {
  display: flex;
  flex-direction: column;       /* 竖排：图片在上，价格在下 */
  align-items: flex-start;      /* 左对齐 */
  gap: 8rpx;
  flex-shrink: 0;
}
.menu-image {
  width: 168rpx;
  height: 168rpx;
  border-radius: 24rpx;
  background: #f8ecdf;
  overflow: hidden;
  border: 1px solid #b07a66;        /* 宽度 样式 颜色 */
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.12); 
  display: block;
}

.menu-image > image {
  width: 100%;
  height: 100%;
}

.menu-price {
  color: var(--primary);
  font-size: 28rpx;
  font-weight: 700;
  flex-shrink: 0;  
  padding-left: 4rpx;
  padding-top: 20rpx;
}
.menu-content {
  flex:1;
  display: flex;
  gap: 14rpx;
  flex-direction: column;           /* 垂直排列 */
  justify-content: space-between;   /* 上下两端对齐 */
  min-width: 0;                     /* 防止溢出 */
}

.menu-name {
  color: var(--ink);
  font-size: 35rpx;
  font-weight: 700;
  line-height: 1.3;
  flex-shrink: 0;
}

.menu-desc {
  display: block;
  color: var(--muted);
  font-size: 26rpx;
  line-height: 1.55;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin: 6rpx 0;
}
.menu-bottom {
  display: flex;
  flex-direction: row;           /* 关键：水平排列 */
  align-items: center;
  justify-content: space-between; /* 价格靠左，按钮靠右 */
  width: 100%;     
}


.row-actions {
  display: flex;
  align-items: center;
  gap: 0;
  color: var(--muted);
  font-size: 26rpx;
}



.menu-action {
  color: #b07a66;
  font-size: 26rpx;
  padding: 4rpx 8rpx;
  line-height: 1.4;
}

.menu-action-danger {
  color: #C2674E;
}
