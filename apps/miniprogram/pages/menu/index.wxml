<view class="container menu-page">
  <button class="primary-btn full-btn" bindtap="goCreate">添加菜品</button>

  <view wx:if="{{hasItems}}" class="menu-list">
    <view wx:for="{{items}}" wx:key="id" class="card menu-row">
      <view class="menu-image">
        <image wx:if="{{item.imageUrl}}" src="{{item.imageUrl}}" mode="aspectFill" />
      </view>
      <view class="menu-content">
        <view class="menu-head">
          <view class="menu-name">{{item.name}}</view>
          <view class="{{item.statusTagClass}}">{{item.statusText}}</view>
        </view>
        <view class="muted">{{item.description}}</view>
        <view class="muted">{{item.textPriceText}}</view>
        <view class="row-actions">
          <button class="secondary-btn tiny-btn" data-id="{{item.id}}" data-status="{{item.status}}" bindtap="toggleStatus">{{item.toggleActionText}}</button>
          <button class="secondary-btn tiny-btn" data-id="{{item.id}}" bindtap="removeItem">删除</button>
        </view>
      </view>
    </view>
  </view>

  <view wx:else class="card">
    <view class="section-title">还没有菜品</view>
    <view class="muted">先添加一道菜，后续就可以在点单页被搜索和加入购物车。</view>
  </view>
</view>
