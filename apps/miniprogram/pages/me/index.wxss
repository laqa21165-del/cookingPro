.user-header-card {
  display: grid;
  gap: 24rpx;
}

.user-top {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.user-avatar {
  width: 116rpx;
  height: 116rpx;
  border-radius: 50%;
  background: #f3e0d6;
  color: #b35f42;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  font-weight: 700;
}

.user-name {
  color: var(--ink);
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.3;
}

.user-role {
  margin-top: 10rpx;
  color: var(--muted);
  font-size: 33rpx;
  line-height: 1.5;
}

.user-stats {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.stat-chip {
  min-height: 76rpx;
  border-radius: 999rpx;
  background: #f4dfd4;
  color: #b56649;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
}

.stat-chip-green {
  background: #e8f2e4;
  color: #53794d;
}

.settings-card {
  display: grid;
  gap: 16rpx;
}

.tip-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 14rpx 18rpx;
  border-radius: 999rpx;
  background: #f9ebdf;
}

.tip-icon {
  width: 52rpx;
  height: 52rpx;
}

.tip-text {
  color: #c06b49;
  font-size: 24rpx;
  font-weight: 600;
}

.identity-list {
  display: flex;
  gap: 18rpx;
}

.identity-chip {
  min-height: 82rpx;
  border-radius: 999rpx;
  background: #f2dfd4;
  color: #b07a66;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
}

.identity-chip-active {
  background: var(--primary);
  color: var(--on-primary);
}

.binding-group + .binding-group {
  margin-top: 28rpx;
}

.binding-group-title {
  margin-bottom: 16rpx;
  color: var(--muted);
  font-size: 24rpx;
  font-weight: 600;
}

.binding-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 18rpx;
  align-items: center;
}

.binding-row + .binding-row {
  margin-top: 22rpx;
}

.binding-name {
  color: var(--ink);
  font-size: 30rpx;
  font-weight: 700;
}

.binding-delete {
  min-width: 160rpx;
  min-height: 68rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #f2dfd4;
  color: #b16a52;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
}

.binding-empty {
  margin-top: 12rpx;
}
