.me-page {
  display: grid;
  gap: 18rpx;
}

.profile-card {
  display: grid;
  gap: 14rpx;
}

.user-header {
  display: grid;
  gap: 20rpx;
  padding: 26rpx 28rpx;
}

.user-top {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.user-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 28rpx;
  flex: none;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(145deg, #f8d9c9, #e9b89f);
  color: #7a3428;
  font-size: 40rpx;
  font-weight: 700;
}

.user-meta {
  min-width: 0;
}

.user-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #3b251f;
  line-height: 1.3;
  word-break: break-word;
}

.user-role {
  display: inline-block;
  margin-top: 10rpx;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(203, 109, 90, 0.12);
  color: #9a5638;
  font-size: 22rpx;
  font-weight: 600;
}

.user-stats {
  display: flex;
  border-top: 1rpx solid rgba(184, 91, 70, 0.12);
  padding-top: 20rpx;
}

.user-stat {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.user-stat-num {
  font-size: 34rpx;
  font-weight: 700;
  color: #7a3428;
}

.user-stat-label {
  font-size: 22rpx;
  color: #8e6f67;
}

.identity-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.identity-chip {
  padding: 16rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.78);
  border: 1rpx solid rgba(155, 103, 84, 0.12);
  color: #8e6f67;
  font-size: 26rpx;
}

.identity-chip-active {
  background: #3b251f;
  color: #fff8f1;
}

.current-role {
  margin-top: 12rpx;
}

.binding-group + .binding-group {
  margin-top: 18rpx;
}

.binding-group-title {
  margin-bottom: 8rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.binding-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  flex-wrap: wrap;
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(184, 91, 70, 0.1);
}

.binding-row > view:first-child {
  flex: 1;
  min-width: 0;
}

.binding-row:last-of-type {
  border-bottom: none;
}

.binding-name {
  font-size: 28rpx;
  font-weight: 700;
}

.tiny-btn {
  width: auto;
  padding: 0 20rpx;
  min-height: 68rpx;
  font-size: 24rpx;
}

.full-btn {
  width: 100%;
  margin-top: 16rpx;
}

.secondary-gap {
  margin-top: 10rpx;
}