<view class="screen-page" wx:if="{{me}}">
  <view class="screen-stage with-tabbar">
    <image class="screen-doodle star" src="/images/doodles/star.svg" mode="aspectFit" />
    <image class="screen-doodle heart" src="/images/doodles/heart.svg" mode="aspectFit" />
    <image class="screen-doodle wave" src="/images/doodles/squiggle.svg" mode="aspectFit" />

    <view class="screen-header">
      <view class="screen-title">我的</view>
      <view class="screen-mark">☆</view>
    </view>

    <view class="screen-card user-header-card">
      <view class="user-top">
        <view class="user-avatar">{{avatarText}}</view>
        <view class="user-meta">
          <input
            class="user-name-input"
            type="nickname"
            value="{{me.nickname || ''}}"
            placeholder="点击设置昵称"
            placeholder-class="user-name-placeholder"
            bindblur="onNicknameBlur"
            bindconfirm="onNicknameBlur"
            confirm-type="done"
            maxlength="30"
          />
          <view class="user-role">{{roleLabel}}</view>
        </view>
      </view>
      <view class="user-stats">
        <view class="stat-chip">绑定厨师 {{customerBindings.length}}</view>
        <view class="stat-chip stat-chip-green">我的顾客 {{chefBindings.length}}</view>
      </view>
    </view>

    <view class="screen-card">
      <view class="section-title">绑定关系</view>

      <view wx:if="{{hasCustomerBindings}}" class="binding-group">
        <view class="binding-group-title">我绑定的厨师</view>
        <view wx:for="{{customerBindings}}" wx:key="chefId" class="binding-row">
          <view>
            <view class="binding-name">{{item.displayName}}</view>
          </view>
          <button class="binding-delete" data-id="{{item.relatedUserId}}" bindtap="removeBinding">删除</button>
        </view>
      </view>

      <view wx:if="{{hasChefBindings}}" class="binding-group">
        <view class="binding-group-title">绑定我的顾客</view>
        <view wx:for="{{chefBindings}}" wx:key="customerId" class="binding-row">
          <view>
            <view class="binding-name">{{item.displayName}}</view>
          </view>
          <button class="binding-delete" data-id="{{item.relatedUserId}}" bindtap="removeBinding">删除</button>
        </view>
      </view>

      <view wx:if="{{!hasAnyBindings}}" class="binding-empty empty-state">
        <image class="empty-puppy" src="/images/puppy.png" mode="aspectFit" />
        <view class="muted">当前还没有绑定关系，可以回首页继续绑定。</view>
      </view>
    </view>

    <view wx:if="{{canSubscribe}}" class="screen-card">
      <view class="section-title">新订单提醒</view>
      <view class="muted">开启后，有顾客下单会通过微信通知你。</view>
      <button class="binding-delete" bindtap="subscribeChefMessage">开启新订单提醒</button>
    </view>
  </view>
</view>
