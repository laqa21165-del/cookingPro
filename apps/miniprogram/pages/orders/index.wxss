.orders-page {
  display: grid;
  gap: 18rpx;
  align-content: start;
}

.orders-filter-card {
  display: grid;
  gap: 14rpx;
  align-content: start;
}

.orders-list {
  display: grid;
  gap: 18rpx;
}

.mode-tabs {
  display: flex;
  gap: 8rpx;
  padding: 6rpx;
  margin-top: 4rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
  box-sizing: border-box;
  overflow: hidden;
}

.mode-tab {
  flex: 1;
  width: auto;
  min-width: 0;
  min-height: 68rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  color: #8e6f67;
  font-size: 26rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  box-sizing: border-box;
  white-space: nowrap;
}

.mode-tab-active {
  background: #3b251f;
  color: #fff8f1;
}

.empty-order-card,
.order-card {
  display: grid;
  gap: 12rpx;
  align-content: start;
}

.order-card {
  padding-top: 24rpx;
  padding-bottom: 24rpx;
}

.full-btn {
  width: 100%;
  margin-top: 10rpx;
}

.empty-title,
.order-title {
  font-size: 30rpx;
  font-weight: 700;
}

.order-head,
.order-meta,
.order-state-group {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
  align-items: center;
}

.order-head,
.order-meta {
  align-items: flex-start;
}

.order-title,
.order-time {
  flex: 1;
  min-width: 0;
}

.order-state-group {
  flex-shrink: 0;
}

.order-line {
  color: #3b251f;
  font-size: 27rpx;
  line-height: 1.55;
  word-break: break-word;
}

.order-notify {
  max-width: 48%;
  text-align: right;
}

.new-badge {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(203, 109, 90, 0.14);
  color: #b85b46;
  font-size: 22rpx;
  white-space: nowrap;
}

.order-status {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  background: rgba(255, 255, 255, 0.82);
  white-space: nowrap;
}

.order-status.pending {
  color: #d36b3f;
}

.order-status.completed {
  color: #4b8b60;
}