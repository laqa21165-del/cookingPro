.orders-filter-card {
  display: grid;
  gap: 40rpx;
}

.mode-tabs {
  display: flex;
  flex-direction: row;
  gap: 18rpx;
  width: 100%;
}

.mode-tab {
  flex: 1;
  flex: 1;
  width: auto !important;        /* 覆盖默认的 184px */
  margin-left: 0 !important;     /* 覆盖默认的 margin */
  margin-right: 0 !important;
  min-width: 0;
  height: 74rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  background: #f3e3d9;
  color: #C2674E;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  box-sizing: border-box;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.4;
  white-space: nowrap;
}

.mode-tab-active {
  background: var(--primary);
  color: var(--on-primary);
}

.order-card {
  display: grid;
  gap: 16rpx;
}

.order-head {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 16rpx;
  align-items: start;
}

.order-title {
  color: var(--ink);
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.3;
}

.order-state-group {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 12rpx;
}

.order-line {
  color: var(--ink-soft);
  font-size: 28rpx;
  line-height: 1.6;
}

.order-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.empty-order-card .full-btn {
  margin-top: 6rpx;
}
