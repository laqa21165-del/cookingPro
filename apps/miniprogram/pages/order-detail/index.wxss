.snapshot-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 12rpx;
  align-items: center;
  font-size: 30rpx;
  color: #3B251F;
}

.snapshot-row + .snapshot-row {
  margin-top: 18rpx;
}

.snapshot-price {
  color: var(--primary);
  font-size: 30rpx;
  font-weight: 700;
}

.detail-text {
  color: var(--ink);
  font-size: 28rpx;
  line-height: 1.6;
  white-space: pre-wrap;
}

.detail-reply {
  min-height: 84rpx;
  margin-bottom: 18rpx;
}

.detail-primary-btn,
.detail-secondary-btn {
  min-height: 72rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
}

.detail-primary-btn {
  width: 320rpx;
  background: var(--primary);
  color: var(--on-primary);
}

.detail-secondary-btn {
  width: 200rpx;
  margin-top: 20rpx;
  margin-left: auto;
  background: #f3e0d5;
  color: #b8684a;
}

.review-item + .review-item {
  margin-top: 20rpx;
}

.review-image {
  width: 100%;
  height: 240rpx;
  margin-top: 12rpx;
  border-radius: 24rpx;
}

.review-empty {
  color: var(--muted);
  font-size: 24rpx;
}
