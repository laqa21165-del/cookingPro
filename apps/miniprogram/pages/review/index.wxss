.review-card {
  display: grid;
  gap: 20rpx;
}

.review-textarea {
  min-height: 250rpx;
}

.upload-btn {
  min-height: 84rpx;
  border-radius: 28rpx;
  background: #f3e2d7;
  color: #b56748;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
}

.image-placeholder {
  width: 100%;
  height: 230rpx;
  border-radius: 28rpx;
  background: #f9eee4;
}

.save-btn {
  min-height: 84rpx;
  border-radius: 28rpx;
  background: var(--primary);
  color: var(--on-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
}
