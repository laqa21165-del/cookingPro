<view class="screen-page">
  <view class="screen-stage">
    <image class="screen-doodle star" src="/images/doodles/star.svg" mode="aspectFit" />
    <image class="screen-doodle heart" src="/images/doodles/heart.svg" mode="aspectFit" />
    <image class="screen-doodle flower" src="/images/doodles/flower.svg" mode="aspectFit" />

    <view class="screen-header">
      <view class="screen-title">新增菜品</view>
      <view class="screen-mark">☆</view>
    </view>

    <view class="screen-card form-card">
      <view class="section-title">新增菜品</view>
      <input class="input" data-field="name" placeholder="菜品名称" value="{{form.name}}" bindinput="onFieldInput" />
      <input class="input" data-field="textPrice" type="number" placeholder="下单所需字数" value="{{form.textPrice}}" bindinput="onFieldInput" />
      <textarea class="textarea create-textarea" data-field="description" placeholder="菜品描述" value="{{form.description}}" bindinput="onFieldInput"></textarea>
      <button class="upload-btn" loading="{{uploading}}" bindtap="chooseImage">上传菜品图片</button>
      <image wx:if="{{form.imageUrl}}" class="preview-image" src="{{form.imageUrl}}" mode="aspectFill" />
      <view wx:else class="image-placeholder"></view>
      <button class="save-btn" bindtap="submit">保存菜品</button>
    </view>
  </view>
  <home-tabbar></home-tabbar>
</view>
