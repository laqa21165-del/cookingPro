.form-card {
  display: grid;
  gap: 20rpx;
}

.create-textarea {
  min-height: 220rpx;
}

.upload-btn {
  min-height: 84rpx;
  border-radius: 28rpx;
  background: #f3e2d7;
  color: #b56748;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  border: 1rpx solid #C9A899;
}

.image-placeholder {
  width: 100%;
  height: 220rpx;
  border-radius: 28rpx;
  background: #f9eee4;
}

.save-btn {
  min-height: 96rpx;
  border-radius: 28rpx;
  background: var(--primary);
  color: var(--on-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 700;
}
