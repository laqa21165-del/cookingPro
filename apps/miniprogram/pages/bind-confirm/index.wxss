.bind-card {
  display: grid;
  gap: 20rpx;
}

.tip-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 14rpx 18rpx;
  border-radius: 999rpx;
  background: #f9ebdf;
}

.tip-icon {
  width: 52rpx;
  height: 52rpx;
}

.tip-text {
  color: #c06b49;
  font-size: 24rpx;
  font-weight: 600;
}

.token-box {
  padding: 24rpx;
  border-radius: 24rpx;
  border: 3rpx dashed var(--line-dashed);
  background: #fff8f1;
  color: var(--ink);
  font-size: 28rpx;
  font-weight: 700;
  text-align: center;
  word-break: break-all;
}

.token-input {
  text-align: center;
}

.bind-success {
  min-height: 86rpx;
  border-radius: 28rpx;
  background: #e8f2e4;
  color: #4f754a;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
}
