.selector-card,
.search-card {
  display: grid;
  gap: 18rpx;
}

.chef-strip {
  width: 100%;
  /* white-space: nowrap; */
}

.chef-strip-inner {
  display: flex;
  gap: 12rpx;
  padding-bottom: 4rpx;
  align-items: center;
  width: 100%;
}

.chef-pill {
  min-height: 76rpx;
  padding: 0 36rpx;
  border-radius: 999rpx;
  background: #f2dfd4;
  color: #b07a66;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1;
  white-space: nowrap;
  flex: 0 0 auto;
  width: 49% !important;
}

.chef-pill-active {
  background: var(--primary);
  color: var(--on-primary);
}

.order-empty-state {
  padding: 12rpx 0;
}

.menu-card {
  display: grid;
  grid-template-columns: 168rpx minmax(0, 1fr);
  gap: 20rpx;
  align-items: start;
}

.order-menu-image {
  width: 168rpx;
  height: 168rpx;
  border-radius: 24rpx;
  background: #f8ecdf;
  overflow: hidden;
}

.order-menu-image > image {
  width: 100%;
  height: 100%;
}

.menu-main {
  display: grid;
  gap: 16rpx;
}

.menu-head {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 12rpx;
}

.menu-name {
  color: var(--ink);
  font-size: 30rpx;
  font-weight: 700;
}

.menu-desc {
  margin-top: 8rpx;
  color: var(--muted);
  font-size: 24rpx;
  line-height: 1.55;
}

.menu-price {
  color: var(--primary);
  font-size: 24rpx;
  font-weight: 700;
}

.menu-foot {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.stepper {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.step-btn {
  width: 48rpx;
  height: 48rpx;
  border-radius: 14rpx;
  border: 2rpx solid var(--line);
  background: var(--surface);
  color: var(--ink);
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1;
}

.step-btn.is-disabled {
  opacity: 0.35;
  pointer-events: none;
}

.step-count {
  min-width: 32rpx;
  text-align: center;
  color: var(--ink);
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1;
}

.cart-backdrop {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(59, 37, 31, 0.35);
  z-index: 10;
}

.cart-panel {
  position: fixed;
  left: 28rpx;
  right: 28rpx;
  bottom: calc(env(safe-area-inset-bottom) + 166rpx);
  max-height: 56vh;
  overflow-y: auto;
  display: grid;
  gap: 16rpx;
  z-index: 12;
}

.cart-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 16rpx;
  align-items: center;
}

.cart-name {
  color: var(--ink);
  font-size: 28rpx;
  font-weight: 700;
}

.payment-card {
  display: grid;
  gap: 16rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  background: #fff7f0;
}

.payment-head {
  display: flex;
  justify-content: space-between;
  align-items: start;
  gap: 12rpx;
}

.order-small-title {
  margin-bottom: 0;
}

.order-text {
  min-height: 200rpx;
}

.payment-foot {
  display: grid;
  gap: 16rpx;
}

.count-ok {
  color: var(--sage);
  font-size: 24rpx;
  font-weight: 600;
}

.count-warn {
  color: var(--primary);
  font-size: 24rpx;
  font-weight: 600;
}

.submit-btn {
  width: 100%;
  min-height: 92rpx;
  border-radius: 28rpx;
  background: var(--primary);
  color: var(--on-primary);
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.submit-btn[disabled] {
  opacity: 0.55;
}

.floating-cart {
  position: fixed;
  left: 28rpx;
  right: 28rpx;
  bottom: calc(env(safe-area-inset-bottom) + 166rpx);
  display: none;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 20rpx 22rpx;
  border-radius: 28rpx;
  background: var(--primary);
  color: var(--on-primary);
  box-sizing: border-box;
  z-index: 11;
}

.floating-cart.is-visible {
  display: flex;
}

.floating-cart > view:first-child {
  flex: 1;
  min-width: 0;
}

.floating-title {
  color: var(--on-primary);
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.35;
}

.floating-copy,
.floating-action {
  color: var(--on-primary);
  font-size: 22rpx;
  line-height: 1.5;
}

.floating-action {
  white-space: nowrap;
  font-weight: 600;
}
