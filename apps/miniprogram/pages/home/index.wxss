.home-page {
  display: grid;
  gap: 18rpx;
}

.hero-card {
  display: grid;
  gap: 18rpx;
  border-radius: 28rpx;
  padding: 30rpx 28rpx;
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.88), rgba(255, 235, 224, 0.82));
  border: 1rpx solid rgba(255, 255, 255, 0.84);
  box-shadow: 0 16rpx 34rpx rgba(124, 86, 68, 0.08);
}

.hero-title {
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.22;
  letter-spacing: -0.03em;
}

.hero-copy {
  margin-top: 12rpx;
  color: #8e6f67;
  font-size: 26rpx;
  line-height: 1.62;
}

.hero-actions {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.hero-btn {
  flex: 1;
  min-width: 0;
}

.notice-card {
  border-radius: 22rpx;
  padding: 20rpx 24rpx;
  background: rgba(238, 248, 233, 0.92);
  border: 1rpx solid rgba(255, 255, 255, 0.85);
}

.notice-title {
  color: #365739;
  font-size: 30rpx;
  font-weight: 700;
}

.notice-text {
  margin-top: 6rpx;
  color: #567a55;
  font-size: 25rpx;
  line-height: 1.5;
}

.share-card {
  display: grid;
  gap: 16rpx;
}

.share-title {
  margin-bottom: 0;
}

.share-preview {
  border-radius: 20rpx;
  padding: 18rpx;
  background: rgba(255, 244, 238, 0.76);
}

.share-preview-title {
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.45;
}

.share-preview-copy {
  margin-top: 8rpx;
  color: #8e6f67;
  font-size: 25rpx;
  line-height: 1.55;
}

.token-box {
  padding: 20rpx 22rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.84);
  border: 1rpx dashed rgba(203, 109, 90, 0.34);
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 0.06em;
  line-height: 1.4;
  text-align: center;
  word-break: break-all;
}

.share-actions {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.share-action-btn {
  flex: 1;
  min-width: 0;
}

.start-order-card {
  display: grid;
  gap: 10rpx;
  justify-items: center;
  text-align: center;
  border-radius: 26rpx;
  padding: 36rpx 28rpx;
  background: linear-gradient(135deg, #C67B5C 0%, #B0654B 100%);
  box-shadow: 0 14rpx 30rpx rgba(160, 90, 60, 0.28);
}

.start-order-title {
  font-size: 48rpx;
  font-weight: 800;
  letter-spacing: 0.04em;
  color: #FFF7F0;
  line-height: 1.2;
}

.start-order-sub {
  font-size: 24rpx;
  color: rgba(255, 247, 240, 0.86);
  line-height: 1.5;
}

.recent-card {
  display: grid;
  gap: 16rpx;
}

.no-gap {
  margin-bottom: 0;
}

.empty-card {
  border-radius: 22rpx;
  padding: 22rpx;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(155, 103, 84, 0.12);
}

.empty-title {
  margin-bottom: 8rpx;
  font-size: 29rpx;
  font-weight: 700;
}

.chef-grid {
  display: grid;
  gap: 12rpx;
}

.chef-card {
  display: grid;
  grid-template-columns: 92rpx 1fr;
  align-items: center;
  gap: 16rpx;
  border-radius: 22rpx;
  padding: 18rpx;
  background: linear-gradient(145deg, rgba(255, 245, 240, 0.95), rgba(255, 227, 214, 0.85));
  text-align: left;
}

.chef-avatar {
  width: 92rpx;
  height: 92rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(203, 109, 90, 0.14);
  color: #984635;
  font-size: 34rpx;
  font-weight: 700;
}

.chef-meta {
  min-width: 0;
}

.chef-name {
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.3;
}

.chef-copy {
  margin-top: 6rpx;
  color: #8e6f67;
  font-size: 24rpx;
  line-height: 1.5;
}