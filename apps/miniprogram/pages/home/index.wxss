.home-page {
  min-height: 100vh;
  padding: 24rpx 16rpx 180rpx;
  background: #fff7f2;
  box-sizing: border-box;
}

.home-stage {
  position: relative;
  min-height: calc(100vh - 204rpx);
  padding: 0 34rpx 58rpx;
  
  border-radius: 58rpx;
  background: linear-gradient(180deg,  #fff7f2 100%);
  overflow: hidden;
  box-sizing: border-box;
}

.home-safe-top {
  width: 100%;
  min-height: 24rpx;
}

.doodle {
  position: absolute;
  z-index: 1;
  pointer-events: none;
}

.doodle-spark {
  top: 176rpx;
  right: 184rpx;
  width: 24rpx;
  height: 24rpx;
}

.doodle-star {
  top: 250rpx;
  right: 140rpx;
  width: 44rpx;
  height: 44rpx;
}

.doodle-heart {
  top: 600rpx;
  left: 38rpx;
  width: 34rpx;
  height: 34rpx;
  z-index: 3;
}

.doodle-flower {
  top: 830rpx;
  right: 46rpx;
  width: 34rpx;
  height: 34rpx;
}

.doodle-wave {
  top: 600rpx;
  right: 90rpx;
  width: 86rpx;
  height: 28rpx;
  z-index: 3;
}

.home-header,
.hero-card,
.start-btn,
.chip-row,
.inline-notice,
.recent-section,
.todo-section {
  position: relative;
  z-index: 2;
}

.home-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  padding: 2rpx 12rpx 0;
}

.home-header-copy {
  padding-top: 10rpx;
}

.home-header-line {
  color: #5E463D;
  font-size: 28rpx;
  line-height: 1.7;
}

.home-face {
  width: 88rpx;
  height: 88rpx;
  flex-shrink: 0;
}

.hero-card {
  margin-top: 30rpx;
  display: grid;
  grid-template-columns: minmax(0, 1fr) 210rpx;
  gap: 24rpx;
  padding: 34rpx 30rpx 28rpx;
  border: 1rpx solid #C9A899;
  border-radius: 42rpx;
  background: #fffdfb;
}

.hero-title {
  color: #3B251F;
  font-size: 50rpx;
  line-height: 1.1;
  font-weight: 700;
  letter-spacing: -0.04em;
}

.hero-desc {
  margin-top: 20rpx;
  color: #8E6F67;
  font-size: 24rpx;
  line-height: 1.55;
}

.hero-note {
  margin-top: 30rpx;
  color: #C2674E;
  font-size: 24rpx;
  line-height: 1.45;
  font-weight: 600;
}

.hero-art {
  width: 210rpx;
  height: 210rpx;
  border-radius: 28rpx;
  overflow: hidden;
  background: #ffefca;
}

.hero-puppy {
  width: 100%;
  height: 100%;
}

.start-btn {
  display: flex;
  width: 100%;
  padding: 0;
  margin: 40rpx 0 40rpx;
  height: 100rpx;
  border: 0;
  border-radius: 32rpx;
  background: #C2674E;
  color: #fff;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  font-size: 38rpx;
  font-weight: 700;
  box-shadow: 0 16rpx 28rpx rgba(199, 111, 77, 0.2);
  box-sizing: border-box;
}

.start-btn::after {
  display: none;
}

.start-arrow {
  font-size: 34rpx;
}

.chip-row {
  margin-top: 26rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-bottom: 30rpx;
}

.chip {
  height: 90rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx 20rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.chip-icon {
  width: 28rpx;
  height: 40rpx;
}

.chip-invite {
  background: #F6E0D7;
  color: #A8533D;
}

.chip-bind {
  background: #EBF4E7;
  color: #3F6B3C;
}

.inline-notice {
  margin-top: 40rpx;
  padding: 24rpx 26rpx;
  border-radius: 26rpx;
  border: 2rpx solid #d9ae98;
  background: #fff8f1;
}

.success-notice {
  background: #eef7ee;
}

.share-notice {
  background: #fff7f0;
}

.inline-notice-title {
  color: #3b251f;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.4;
}

.inline-notice-text {
  margin-top: 8rpx;
  color: #866b5f;
  font-size: 24rpx;
  line-height: 1.55;
}

.share-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 18rpx;
}

.notice-btn {
  flex: 1;
  height: 68rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.notice-btn::after {
  display: none;
}

.light-btn {
  background: #fff;
  color: #9c694f;
  border: 2rpx solid #e0bcaa;
}

.solid-btn {
  background: #c76f4d;
  color: #fff;
}

.recent-section {
  margin-top: 50rpx;
  padding-bottom: 20rpx;
}

.recent-title {
  color: #3B251F;
  font-size: 36rpx;
  line-height: 1.3;
  font-weight: 700;
}

.recent-subtitle {
  margin-top: 15rpx;
  color: #8E6F67;
  font-size: 22rpx;
  line-height: 1.5;
}

.todo-section {
  margin-top: 40rpx;
  padding-bottom: 20rpx;
}

.todo-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
}

.todo-title {
  color: #3B251F;
  font-size: 36rpx;
  line-height: 1.3;
  font-weight: 700;
}

.todo-more {
  color: #C2674E;
  font-size: 24rpx;
  font-weight: 600;
}

.todo-list {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.todo-card {
  padding: 22rpx 24rpx;
  border: 3rpx solid #C9A899;
  border-radius: 26rpx;
  background: #FFFDFB;
  box-sizing: border-box;
}

.todo-card-top {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.todo-id {
  color: #C2674E;
  font-size: 26rpx;
  font-weight: 700;
}

.todo-badge {
  padding: 2rpx 12rpx;
  border-radius: 999rpx;
  background: #F6E0D7;
  color: #A8533D;
  font-size: 20rpx;
  font-weight: 600;
}

.todo-items {
  margin-top: 12rpx;
  color: #3B251F;
  font-size: 26rpx;
  line-height: 1.45;
}

.todo-meta {
  margin-top: 8rpx;
  color: #8E6F67;
  font-size: 22rpx;
  line-height: 1.5;
}

.chef-grid {
  margin-top: 18rpx;
  display: flex;
  flex-direction: row;          /* 竖排 */
  align-items: flex-start;         /* 靠左对齐 */
  gap: 18rpx;                      /* 卡片间距 */
  width: 100%;
}

.chef-card {
  padding: 20rpx 20rpx 24rpx;
  border: 3rpx solid #C9A899;
  border-radius: 26rpx;
  background: #FFFDFB;
  text-align: left;
  width: 100%;                     /* 占满宽度，但内容靠左 */
  box-sizing: border-box;
}

.chef-card::after {
  display: none;
}

.chef-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #F6E0D7;
  color: #A8533D;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
}

.chef-name {
  margin-top: 16rpx;
  color: #3B251F;
  font-size: 28rpx;
  line-height: 1.3;
  font-weight: 700;
}

.chef-copy {
  margin-top: 8rpx;
  color: #8E6F67;
  font-size: 23rpx;
  line-height: 1.45;
}

.empty-card {
  margin-top: 18rpx;
  padding: 24rpx;
  border: 2rpx dashed #C9A899;
  border-radius: 24rpx;
  background: #FFFDFB;
}

.empty-title {
  color: #3B251F;
  font-size: 28rpx;
  font-weight: 700;
}

.empty-copy {
  margin-top: 10rpx;
  color: #8E6F67;
  font-size: 22rpx;
  line-height: 1.5;
}
