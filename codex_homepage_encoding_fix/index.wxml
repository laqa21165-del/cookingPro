<view class="home-page">
  <view class="home-stage">
    <image class="doodle doodle-spark" src="/images/doodles/spark.svg" mode="aspectFit" />
    <image class="doodle doodle-star" src="/images/doodles/star.svg" mode="aspectFit" />
    <image class="doodle doodle-heart" src="/images/doodles/heart.svg" mode="aspectFit" />
    <image class="doodle doodle-flower" src="/images/doodles/flower.svg" mode="aspectFit" />
    <image class="doodle doodle-wave" src="/images/doodles/squiggle.svg" mode="aspectFit" />

    <view class="greeting-card">
      <view class="greeting-copy">
        <view class="greeting-line">{{greetingTitle}}</view>
        <view class="greeting-line">{{greetingSubline}}</view>
      </view>
      <image class="greeting-face" src="/images/smile-outline.svg" mode="aspectFit" />
    </view>

    <view class="hero-card">
      <view class="hero-main">
        <view class="hero-title">今天想吃什么？</view>
        <view class="hero-desc">用文字点单，每一次点单都会被认真阅读，也会被温柔回应。</view>
        <view class="hero-note">汪，今天的心意，我来替你送到。</view>
      </view>
      <view class="hero-art">
        <image class="hero-puppy" src="/images/peeking-puppy.svg" mode="aspectFit" />
      </view>
    </view>

    <button class="start-btn" bindtap="directEnter">
      <text>开始点菜</text>
      <text class="start-arrow">→</text>
    </button>

    <view class="chip-row">
      <view class="chip chip-invite" bindtap="prepareShare">
        <image class="chip-icon" src="/images/icons/plane.svg" mode="aspectFit" />
        <text>邀请顾客绑定</text>
      </view>
      <view class="chip chip-bind" bindtap="goBindChef">
        <image class="chip-icon" src="/images/icons/person-add.svg" mode="aspectFit" />
        <text>绑定专属厨师</text>
      </view>
    </view>

    <view wx:if="{{bindingConfirmed}}" class="inline-notice success-notice">
      <view class="inline-notice-title">绑定确认成功</view>
      <view class="inline-notice-text">你已经和这位厨师建立关系，现在可以直接点单了。</view>
    </view>

    <view wx:if="{{shareLink}}" class="inline-notice share-notice">
      <view class="inline-notice-title">邀请口令 {{shareLink.token}}</view>
      <view class="inline-notice-text">复制口令或直接分享给对方，对方确认后就能完成绑定。</view>
      <view class="share-actions">
        <button class="notice-btn light-btn" bindtap="copyShareToken">复制口令</button>
        <button class="notice-btn solid-btn" open-type="share">立即分享</button>
      </view>
    </view>

    <view class="recent-section">
      <view class="recent-title">最近可点单的厨师</view>
      <view class="recent-subtitle">当前已绑定 {{customerBindings.length}} 位 · 点进去就能继续下单</view>

      <view wx:if="{{hasBindings}}" class="chef-grid">
        <button
          wx:for="{{customerBindings}}"
          wx:key="chefId"
          class="chef-card"
          data-id="{{item.chefId}}"
          bindtap="chooseChef"
        >
          <view class="chef-avatar">{{item.avatarText}}</view>
          <view class="chef-name">{{item.displayName}}</view>
          <view class="chef-copy">点进来就能继续点单</view>
        </button>
      </view>

      <view wx:else class="empty-card">
        <view class="empty-title">还没有绑定的厨师</view>
        <view class="empty-copy">先通过邀请或口令完成绑定，再回来开始点单。</view>
      </view>
    </view>

    <view class="custom-tabbar">
      <view class="tab-item tab-item-active" bindtap="noopTab">
        <image class="tab-icon" src="/images/icons/tab-home-active.svg" mode="aspectFit" />
        <text>首页</text>
      </view>
      <view class="tab-item" bindtap="goOrdersTab">
        <image class="tab-icon" src="/images/icons/tab-orders.svg" mode="aspectFit" />
        <text>订单</text>
      </view>
      <view class="tab-item" bindtap="goMenuTab">
        <image class="tab-icon" src="/images/icons/tab-menu.svg" mode="aspectFit" />
        <text>菜单</text>
      </view>
      <view class="tab-item" bindtap="goMeTab">
        <image class="tab-icon" src="/images/icons/tab-me.svg" mode="aspectFit" />
        <text>我的</text>
      </view>
    </view>
  </view>
</view>
