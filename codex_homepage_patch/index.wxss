.home-page {
  min-height: 100vh;
  background: #FFF7F2;
  box-sizing: border-box;
}

.home-stage {
  position: relative;
  min-height: 100vh;
  padding: 28rpx 24rpx 164rpx;
  background: #F9F1E8;
  border: 2rpx solid #E0BCAA;
  border-radius: 48rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.hand-font {
  font-family: 'Sarasa Gothic SC', 'PingFang SC', sans-serif;
}

.doodle {
  position: absolute;
  z-index: 1;
  pointer-events: none;
}

.doodle-spark {
  top: 48rpx;
  right: 108rpx;
  width: 28rpx;
  height: 28rpx;
}

.doodle-star {
  top: 86rpx;
  right: 56rpx;
  width: 32rpx;
  height: 32rpx;
}

.doodle-heart {
  top: 410rpx;
  left: 22rpx;
  width: 28rpx;
  height: 28rpx;
}

.doodle-flower {
  top: 694rpx;
  right: 18rpx;
  width: 32rpx;
  height: 32rpx;
}

.doodle-wave {
  top: 394rpx;
  right: 18rpx;
  width: 40rpx;
  height: 22rpx;
}

.greeting-card,
.hero-card,
.inline-notice,
.chef-card,
.empty-state {
  position: relative;
  z-index: 2;
  background: #FFFDFB;
  border: 4rpx solid #C9A99A;
  border-radius: 24rpx;
  box-shadow: none;
  box-sizing: border-box;
}

.greeting-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 24rpx;
}

.greeting-copy {
  min-width: 0;
  flex: 1;
}

.eyebrow {
  color: #8E6F67;
  font-size: 22rpx;
  line-height: 1.4;
  font-weight: 600;
  letter-spacing: 0.12em;
}

.greeting-line {
  margin-top: 8rpx;
  color: #3B251F;
  font-size: 30rpx;
  line-height: 1.3;
  font-weight: 700;
}

.greeting-subline {
  margin-top: 8rpx;
  color: #5E463D;
  font-size: 24rpx;
  line-height: 1.5;
}

.greeting-face {
  width: 72rpx;
  height: 72rpx;
  flex-shrink: 0;
}

.hero-card {
  margin-top: 20rpx;
  padding: 28rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: #FFF8F1;
}

.hero-main {
  min-width: 0;
  flex: 1;
}

.hero-title {
  margin-top: 8rpx;
  color: #3B251F;
  font-size: 52rpx;
  line-height: 1.18;
  font-weight: 700;
  letter-spacing: -0.03em;
}

.hero-desc {
  margin-top: 16rpx;
  color: #5E463D;
  font-size: 28rpx;
  line-height: 1.6;
}

.hero-note {
  margin-top: 20rpx;
  color: #C2674E;
  font-size: 24rpx;
  line-height: 1.5;
  font-weight: 600;
}

.hero-art {
  width: 188rpx;
  height: 188rpx;
  flex-shrink: 0;
  background: #F6E0D7;
  border: 4rpx solid #C9A99A;
  border-radius: 24rpx;
  overflow: hidden;
  box-sizing: border-box;
}

.hero-puppy {
  width: 100%;
  height: 100%;
}

.start-btn {
  position: relative;
  z-index: 2;
  width: 100%;
  min-height: 84rpx;
  margin-top: 24rpx;
  padding: 0 24rpx;
  background: #C2674E;
  color: #FFF9F5;
  border: 4rpx solid #A8533D;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 28rpx;
  line-height: 1.5;
  font-weight: 600;
  box-sizing: border-box;
}

.start-btn::after {
  display: none;
}

.start-arrow {
  font-size: 28rpx;
  line-height: 1;
}

.chip-row {
  position: relative;
  z-index: 2;
  margin-top: 24rpx;
  display: flex;
  gap: 16rpx;
}

.chip {
  flex: 1;
  min-height: 76rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  border: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  font-size: 24rpx;
  line-height: 1.5;
  font-weight: 600;
  box-sizing: border-box;
}

.chip::after {
  display: none;
}

.chip-icon {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
}

.chip-invite {
  background: #F6E2DA;
  color: #C2674E;
}

.chip-bind {
  background: #E4F1E4;
  color: #5F8B5B;
}

.inline-notice {
  margin-top: 20rpx;
  padding: 24rpx;
}

.success-notice {
  background: #EBF4E7;
}

.share-notice {
  background: #FFF8F1;
}

.inline-notice-title {
  margin-top: 8rpx;
  color: #3B251F;
  font-size: 30rpx;
  line-height: 1.3;
  font-weight: 700;
}

.inline-notice-text {
  margin-top: 8rpx;
  color: #5E463D;
  font-size: 24rpx;
  line-height: 1.5;
}

.share-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 20rpx;
}

.notice-btn {
  flex: 1;
  min-height: 84rpx;
  padding: 0 16rpx;
  font-size: 28rpx;
  line-height: 1.5;
  font-weight: 600;
  box-sizing: border-box;
}

.notice-btn::after {
  display: none;
}

.primary-btn,
.secondary-btn {
  border-radius: 20rpx;
}

.primary-btn {
  background: #C2674E;
  color: #FFF9F5;
  border: 4rpx solid #A8533D;
}

.secondary-btn {
  background: #FFFDFB;
  color: #3B251F;
  border: 4rpx solid #C9A99A;
}

.recent-section {
  position: relative;
  z-index: 2;
  margin-top: 34rpx;
}

.recent-header {
  margin-bottom: 18rpx;
}

.recent-title {
  margin-top: 8rpx;
  color: #3B251F;
  font-size: 36rpx;
  line-height: 1.3;
  font-weight: 700;
}

.recent-subtitle {
  margin-top: 8rpx;
  color: #8E6F67;
  font-size: 24rpx;
  line-height: 1.5;
}

.chef-grid {
  display: flex;
  flex-wrap: wrap;
  margin-left: -8rpx;
  margin-right: -8rpx;
}

.chef-card {
  width: calc(50% - 16rpx);
  margin: 0 8rpx 16rpx;
  padding: 24rpx;
  text-align: left;
}

.chef-card::after {
  display: none;
}

.chef-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  background: #F6E2DA;
  color: #A8533D;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  line-height: 1.5;
  font-weight: 700;
}

.chef-name {
  margin-top: 16rpx;
  color: #3B251F;
  font-size: 30rpx;
  line-height: 1.3;
  font-weight: 700;
}

.chef-copy {
  margin-top: 8rpx;
  color: #5E463D;
  font-size: 24rpx;
  line-height: 1.5;
}

.empty-state {
  padding: 24rpx;
  text-align: center;
}

.empty-puppy {
  width: 180rpx;
  height: 180rpx;
  margin: 0 auto;
  display: block;
}

.empty-title {
  margin-top: 16rpx;
  color: #C2674E;
  font-size: 30rpx;
  line-height: 1.3;
  font-weight: 700;
}

.empty-copy {
  margin-top: 12rpx;
  color: #5E463D;
  font-size: 24rpx;
  line-height: 1.5;
}

.custom-tabbar {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 4;
  height: 112rpx;
  padding-top: 12rpx;
  display: flex;
  background: rgba(252, 245, 238, 0.96);
  border-top: 2rpx solid #E0BCAA;
  box-sizing: border-box;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  gap: 8rpx;
  color: #9B8073;
  font-size: 20rpx;
  line-height: 1;
  font-weight: 600;
}

.tab-item-active {
  color: #C2674E;
}

.tab-icon {
  width: 32rpx;
  height: 32rpx;
}